{
  "name": "obs-visu-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "pnpm workspace for the obs Visu app (apps/visu) and its versioned contract (packages/contract).",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "eslint apps packages",
    "format": "prettier --check \"apps/**/*.{ts,tsx,vue,json}\" \"packages/**/*.{ts,tsx,vue,json}\" eslint.config.js .dependency-cruiser.cjs .prettierrc.json pnpm-workspace.yaml .github/workflows/visu-ci.yml",
    "boundaries": "depcruise apps packages",
    "m1:smoke": "pnpm --dir apps/visu m1:smoke"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "dependency-cruiser": "^16.8.0",
    "eslint": "^9.16.0",
    "eslint-plugin-vue": "^9.32.0",
    "prettier": "^3.4.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.18.0",
    "vue-eslint-parser": "^9.4.3"
  }
}
