#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(git -C "$SCRIPT_DIR/.." rev-parse --show-toplevel)"

MAIN_WORKTREE=""
while IFS= read -r line; do
  case "$line" in
    worktree\ *)
      MAIN_WORKTREE="${line#worktree }"
      break
      ;;
  esac
done < <(git -C "$REPO_ROOT" worktree list --porcelain)

if [ -z "$MAIN_WORKTREE" ]; then
  echo "link-worktree-node-modules: could not determine main worktree" >&2
  exit 1
fi

MAIN_NODE_MODULES="$MAIN_WORKTREE/gui/node_modules"
if [ ! -d "$MAIN_NODE_MODULES" ]; then
  cat >&2 <<EOF
link-worktree-node-modules: main worktree GUI dependencies are missing:
  $MAIN_NODE_MODULES

Install or update GUI dependencies in the shared main worktree, then rerun this command:
  cd "$MAIN_WORKTREE/gui" && npm ci
EOF
  exit 1
fi

git -C "$REPO_ROOT" worktree list --porcelain |
  awk '/^worktree /{print substr($0,10)}' |
  while IFS= read -r worktree; do
    [ "$worktree" = "$MAIN_WORKTREE" ] && continue
    [ -d "$worktree/gui" ] || continue

    target="$worktree/gui/node_modules"
    if [ -e "$target" ] || [ -L "$target" ]; then
      printf 'skip existing gui/node_modules: %s\n' "$worktree"
      continue
    fi

    if [ -f "$MAIN_WORKTREE/gui/package-lock.json" ] && [ -f "$worktree/gui/package-lock.json" ] &&
      ! cmp -s "$MAIN_WORKTREE/gui/package-lock.json" "$worktree/gui/package-lock.json"; then
      printf 'warning: package-lock differs from main worktree: %s\n' "$worktree" >&2
    fi

    ln -s "$MAIN_NODE_MODULES" "$target"
    printf 'linked gui/node_modules: %s\n' "$worktree"
  done
