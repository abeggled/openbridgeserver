# open bridge server — Environment Variable Overrides
# Copy to .env and adjust for your environment.
# All OBS_* variables override config.yaml (highest priority).

# ── Security (REQUIRED in production) ──────────────────────────────────────
OBS_JWT_SECRET=change-this-to-a-random-secret-min-32-chars

# ── MQTT service account ────────────────────────────────────────────────────
# open bridge server connects to Mosquitto with these credentials.
# Must match the password Mosquitto was initialized with.
# Change both values together and restart the stack.
OBS_MQTT_USERNAME=obs
OBS_MQTT_PASSWORD=change-this-mqtt-service-password

# ── Log level ───────────────────────────────────────────────────────────────
OBS_LOG_LEVEL=INFO

# ── Database path (inside container: /data is the volume) ──────────────────
# OBS_DATABASE__PATH=/data/obs.db

# ── RingBuffer ──────────────────────────────────────────────────────────────
# OBS_RINGBUFFER__STORAGE=disk
# OBS_RINGBUFFER__MAX_ENTRIES=50000

# ── CORS (optional) ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the REST API.
# Default: localhost dev servers only. Set to your GUI origin in production.
# OBS_CORS__ORIGINS='["https://obs.example.com"]'

# ── Mosquitto passwd management (advanced / bare-metal) ─────────────────────
# In Docker Compose the defaults in docker-compose.yml are used automatically.
# For bare-metal deployments, override these as needed:
# OBS_MOSQUITTO__PASSWD_FILE=/etc/mosquitto/passwd
# OBS_MOSQUITTO__RELOAD_PID=       # PID of the Mosquitto process
# OBS_MOSQUITTO__RELOAD_COMMAND=   # e.g. "kill -HUP $(cat /var/run/mosquitto/mosquitto.pid)"
# OBS_MOSQUITTO__SERVICE_USERNAME=obs
# OBS_MOSQUITTO__SERVICE_PASSWORD=change-this-mqtt-service-password
