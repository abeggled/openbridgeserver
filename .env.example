# openTWS — Environment Variable Overrides
# Copy to .env and adjust for your environment.
# All OPENTWS_* variables override config.yaml (highest priority).

# ── Security (REQUIRED in production) ──────────────────────────────────────
OPENTWS_JWT_SECRET=change-this-to-a-random-secret-min-32-chars

# ── MQTT service account ────────────────────────────────────────────────────
# openTWS connects to Mosquitto with these credentials.
# Must match the password Mosquitto was initialized with.
# Change both values together and restart the stack.
OPENTWS_MQTT_USERNAME=opentws
OPENTWS_MQTT_PASSWORD=change-this-mqtt-service-password

# ── Log level ───────────────────────────────────────────────────────────────
OPENTWS_LOG_LEVEL=INFO

# ── Database path (inside container: /data is the volume) ──────────────────
# OPENTWS_DATABASE__PATH=/data/opentws.db

# ── RingBuffer ──────────────────────────────────────────────────────────────
# OPENTWS_RINGBUFFER__STORAGE=disk
# OPENTWS_RINGBUFFER__MAX_ENTRIES=50000

# ── CORS (optional) ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the REST API.
# Default: localhost dev servers only. Set to your GUI origin in production.
# OPENTWS_CORS__ORIGINS='["https://opentws.example.com"]'

# ── Mosquitto passwd management (advanced / bare-metal) ─────────────────────
# In Docker Compose the defaults in docker-compose.yml are used automatically.
# For bare-metal deployments, override these as needed:
# OPENTWS_MOSQUITTO__PASSWD_FILE=/etc/mosquitto/passwd
# OPENTWS_MOSQUITTO__RELOAD_PID=       # PID of the Mosquitto process
# OPENTWS_MOSQUITTO__RELOAD_COMMAND=   # e.g. "kill -HUP $(cat /var/run/mosquitto/mosquitto.pid)"
# OPENTWS_MOSQUITTO__SERVICE_USERNAME=opentws
# OPENTWS_MOSQUITTO__SERVICE_PASSWORD=change-this-mqtt-service-password
