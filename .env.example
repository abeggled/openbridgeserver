# OpenTWS — Environment Variable Overrides
# Copy to .env and adjust for your environment.
# All OPENTWS_* variables override config.yaml (highest priority).

# ── Security (REQUIRED in production) ──────────────────────────────────────
OPENTWS_JWT_SECRET=change-this-to-a-random-secret-min-32-chars

# ── Log level ───────────────────────────────────────────────────────────────
OPENTWS_LOG_LEVEL=INFO

# ── MQTT (if Mosquitto requires auth) ──────────────────────────────────────
# OPENTWS_MQTT__USERNAME=opentws
# OPENTWS_MQTT__PASSWORD=mqttpassword

# ── Database path (inside container: /data is the volume) ──────────────────
# OPENTWS_DATABASE__PATH=/data/opentws.db

# ── RingBuffer ──────────────────────────────────────────────────────────────
# OPENTWS_RINGBUFFER__STORAGE=disk
# OPENTWS_RINGBUFFER__MAX_ENTRIES=50000
